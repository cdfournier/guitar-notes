<fieldset>
  <label for="<%= toggleId %>">
    <span class="light-mode">
      <svg xmlns="http://www.w3.org/2000/svg" class="icon sun" viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <path d="M0 0h24v24H0z" stroke="none"></path>
        <circle cx="12" cy="12" r="4"></circle>
        <path d="M3 12h1m8-9v1m8 8h1m-9 8v1M5.6 5.6l.7.7m12.1-.7-.7.7m0 11.4.7.7m-12.1-.7-.7.7"></path>
      </svg>
    </span>
    <input type="checkbox" name="<%= toggleId %>" class="switch" id="<%= toggleId %>" data-theme-toggle>
    <span class="dark-mode">
      <svg xmlns="http://www.w3.org/2000/svg" class="icon moon" viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <path d="M0 0h24v24H0z" stroke="none"></path>
        <path d="M12 3h.393a7.5 7.5 0 0 0 7.92 12.446A9 9 0 1 1 12 2.992z"></path>
      </svg>
    </span>
  </label>
</fieldset>
